# Postgres username
POSTGRES_USER=DB_USER

# Postgres host
POSTGRES_HOST=DB_HOST

# Postgres password
POSTGRES_PASSWORD=DB_PASSWORD

# Postgres database name
POSTGRES_DATABASE=DB_NAME

# Pooled connection URL
POSTGRES_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME

# Pooled connection URL without SSL
POSTGRES_URL_NO_SSL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME

# Pooled connection URL with pgbouncer, used by Prisma
POSTGRES_PRISMA_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME?pgbouncer=true

# Direct non-pooled connection URL, used for migrations
POSTGRES_URL_NON_POOLING=postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME

# Vercel Blob store ID
BLOB_STORE_ID=BLOB_STORE_ID

# Vercel Blob read/write token
BLOB_READ_WRITE_TOKEN=BLOB_RW_TOKEN

# SMTP server hostname
HOST=SMTP_HOST

# SMTP port
MAILER_PORT=SMTP_PORT

# Sender email address
EMAIL=SMTP_EMAIL

# Sender email password
EMAIL_PASS=SMTP_EMAIL_PASS

# Institution recipient email address
INSTITUTION_EMAIL=INSTITUTION_EMAIL

# Google reCAPTCHA v2 public site key (client-side)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=RECAPTCHA_SITE_KEY

# Google reCAPTCHA v2 secret key (server-side)
RECAPTCHA_SECRET_KEY=RECAPTCHA_SECRET_KEY

# App environment: development | production | test
NODE_ENV=development
